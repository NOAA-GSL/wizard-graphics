{
    "name": "desi-graphics",
    "version": "1.0.2",
    "description": "An extension of deck.gl for producing weather graphics",
    "type": "module",
    "license": "MIT",
    "main": "./dist/desi-graphics.umd.cjs",
    "module": "./dist/desi-graphics.js",
    "exports": {
        ".": {
            "import": "./dist/desi-graphics.js",
            "require": "./dist/desi-graphics.umd.cjs"
        },
        "./style.css": "./dist/style.css"
    },
    "files": [
        "dist"
    ],
    "homepage": "https://vlab.noaa.gov/gitlab-community/OAR/GSL/DESI/desi-graphics",
    "scripts": {
        "predev": "node src/generateJson.js",
        "dev": "vite",
        "build": "vite build",
        "lint": "eslint .",
        "preview": "vite preview",
        "size": "npx vite-bundle-visualizer"
    },
    "dependencies": {
        "@vitejs/plugin-react": "^4.3.1",
        "rbush": "^4.0.1",
        "vite": "^5.4.1"
    },
    "devDependencies": {
        "@eslint/js": "^8.57.1",
        "@types/react": "^18.3.3",
        "@types/react-dom": "^18.3.0",
        "eslint": "^8.57.1",
        "eslint-config-airbnb": "^19.0.4",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-import": "^2.31.0",
        "eslint-plugin-prettier": "^5.2.1",
        "eslint-plugin-react": "^7.35.0",
        "eslint-plugin-react-hooks": "^4.6.0",
        "eslint-plugin-react-refresh": "^0.4.9",
        "globals": "^15.9.0",
        "sass": "^1.80.3",
        "vite-plugin-static-copy": "^1.0.6"
    },
    "//": "Still figuring out best way to manage peerDependency versions",
    "peerDependencies": {
        "d3": ">=7.0.0",
        "deck.gl": ">=9.0.0",
        "lodash": ">=4.0.0",
        "maplibre-gl": ">=4.0.0",
        "proj4": ">=2.0.0",
        "react": ">=18.0.0 <20.0.0",
        "react-dom": ">=18.0.0 <20.0.0",
        "react-map-gl": ">=7.0.0"
    }
}
